# ============================================================
#  VideoGen AI — 100% FREE Configuration
#  No paid APIs required! All services below are completely free.
# ============================================================

# ── Flask ────────────────────────────────────────────────────
SECRET_KEY=videogen-free-2024-secret
DEBUG=False
PORT=5000

# ── Pexels (FREE B-Roll footage — 200 req/hour) ─────────────
# Get free key at: https://www.pexels.com/api/
PEXELS_API_KEY=your-free-pexels-key

# ── Pixabay (FREE B-Roll + Music — 100 req/min) ─────────────
# Get free key at: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your-free-pixabay-key

# ── Freesound (FREE Sound Effects) ─────────────────────────
# Get free key at: https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=your-free-freesound-key

# ── TTS Settings (No API key needed!) ───────────────────────
DEFAULT_TTS=edge_tts       # edge_tts | gtts | pyttsx3
DEFAULT_VOICE=en-US-AriaNeural  # Edge TTS voice name

# ── Whisper Settings (Runs locally — no API key needed!) ────
WHISPER_MODEL=base         # tiny | base | small | medium | large
# tiny=fastest, base=good balance, small=better, medium=best free quality

# ── Upload Limits ────────────────────────────────────────────
MAX_CONTENT_LENGTH=500     # MB - for raw video uploads
OUTPUT_DIR=static/outputs
UPLOAD_DIR=static/uploads
